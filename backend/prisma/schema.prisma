// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// Platformy
enum Marketplace {
  ALLEGRO
  ERLI
}

// Status konta marketplace
enum MarketplaceAccountStatus {
  ACTIVE
  DISCONNECTED
  ERROR
}

// Wewnętrzny status zamówienia w Twojej aplikacji
enum OrderStatus {
  NEW
  PROCESSING
  SENT
  CANCELLED
}


enum ShippingProvider {
  INPOST_SHIPX
}

enum ShippingAccountStatus {
  ACTIVE
  DISCONNECTED
  ERROR
}


model User {
  // Główne ID użytkownika
  id Int @id @default(autoincrement())

  // Login użytkownika do Twojego panelu
  email String @unique

  // Hasło hash np. bcrypt
  passwordHash String

  // Dane użytkownika
  firstName   String?
  lastName    String?
  companyName String?
  taxId       String?
  phone       String?

  // Domyślna drukarka etykiet użytkownika
  // Nazwa musi odpowiadać nazwie drukarki widocznej w systemie / QZ Tray,
  // np. "ZDesigner GC420d" albo "Zebra GC420d".
  labelPrinterName     String?
  labelPrinterFormat   String? @default("zpl")
  labelPrinterDpi      Int?    @default(203)
  labelPrinterWidthMm  Int?    @default(100)
  labelPrinterHeightMm Int?    @default(150)

  // Jeden user może mieć wiele kont marketplace
  marketplaceAccounts MarketplaceAccount[]

  // Logowania OAuth
  oauthStates OAuthState[]

  // Zamówienia usera
  orders Order[]

  // Daty automatyczne
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  sessions Session[]

  shippingAccounts ShippingAccount[]
  shipments Shipment[]

  @@map("users")
}

model MarketplaceAccount {
  // ID lokalnego konta marketplace
  id Int @id @default(autoincrement())

  // Do którego użytkownika Twojego panelu należy to konto
  userId Int

  // Relacja do Usera
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Jaka platforma: ALLEGRO / ERLI
  marketplace Marketplace

  // Status konta
  status MarketplaceAccountStatus @default(DISCONNECTED)

  // Nazwa konta w panelu
  accountName String?

  // ID konta z platformy, np. Allegro user id albo ERLI account id
  externalAccountId String?

  // Tokeny OAuth / API
  accessToken    String?
  refreshToken   String?
  tokenType      String?
  tokenExpiresAt DateTime?

  // Ostatni błąd integracji
  errorMessage String?

  // Logowania OAuth dla tego konta
  oauthStates OAuthState[]

  // Zamówienia z tego konta marketplace
  orders Order[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  

  @@index([userId])
  @@index([userId, marketplace])
  @@index([marketplace])
  @@index([externalAccountId])

  @@map("marketplace_accounts")
}

model OAuthState {
  // ID rekordu OAuthState
  id Int @id @default(autoincrement())

  // Losowy token state
  stateToken String @unique

  // Kto rozpoczął logowanie
  userId Int

  // Relacja do Usera
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Do którego lokalnego konta marketplace ma trafić token
  marketplaceAccountId Int

  // Relacja do MarketplaceAccount
  marketplaceAccount MarketplaceAccount @relation(fields: [marketplaceAccountId], references: [id], onDelete: Cascade)

  // Dla jakiej platformy jest to logowanie
  marketplace Marketplace

  // Kiedy state wygasa
  expiresAt DateTime

  // Kiedy state został użyty
  // Jeśli null, jeszcze nieużyty
  usedAt DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([stateToken])
  @@index([marketplaceAccountId])
  @@index([marketplace])
  @@index([expiresAt])

  @@map("oauth_states")
}

model Order {
  // Lokalne ID zamówienia w Twojej bazie
  id Int @id @default(autoincrement())

  // ID zamówienia z zewnętrznej platformy
  // Np. Allegro checkoutForm.id albo ERLI order id
  externalOrderId String

  // Platforma, z której pochodzi zamówienie
  marketplace Marketplace

  // Właściciel zamówienia w Twojej aplikacji
  userId Int
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Konto marketplace, z którego pobrano zamówienie
  marketplaceAccountId Int
  marketplaceAccount MarketplaceAccount @relation(fields: [marketplaceAccountId], references: [id], onDelete: Cascade)

  // Twój wewnętrzny status zamówienia
  status OrderStatus @default(NEW)

  // Statusy z platformy jako tekst, bo Allegro i ERLI mogą mieć różne wartości
  externalOrderStatus         String?
  externalFulfillmentStatus   String?
  externalLineItemsSentStatus String?

  // Kwoty
  totalAmount Decimal? @db.Decimal(12, 2)
  totalToPay  Decimal? @db.Decimal(12, 2)
  currency    String   @default("PLN")

  // Daty
  orderCreatedAt   DateTime?
  externalUpdatedAt DateTime?
  syncedAt         DateTime?

  // Dostawa
  deliveryMethodId   String?
  deliveryMethodName String?

  deliveryFirstName   String?
  deliveryLastName    String?
  deliveryStreet      String?
  deliveryCity        String?
  deliveryZipCode     String?
  deliveryCountryCode String?
  deliveryPhone       String?

  // Punkt odbioru / paczkomat
  pickupPointId   String?
  pickupPointName String?

  // Koszt dostawy
  deliveryCost     Decimal? @db.Decimal(12, 2)
  deliveryCurrency String?
  deliverySmart    Boolean  @default(false)

  // Kupujący
  buyerId          String?
  buyerLogin       String?
  buyerEmail       String?
  buyerFirstName   String?
  buyerLastName    String?
  buyerCompanyName String?
  buyerPhone       String?
  buyerGuest       Boolean @default(false)

  // Wiadomość od kupującego
  messageToSeller String?

  // Płatność
  paymentId         String?
  paymentType       String?
  paymentProvider   String?
  paymentFinishedAt DateTime?
  paymentAmount     Decimal? @db.Decimal(12, 2)
  paymentCurrency   String?

  // Faktura
  invoiceRequired Boolean @default(false)

  // Revision / version / token wersji zamówienia z platformy
  externalRevision String?

  // Np. allegro-pl, erli-pl itd.
  marketplaceSiteId String?

  // Surowe dane z API platformy
  // Przydatne, jeśli później okaże się, że brakuje jakiegoś pola w tabeli
  rawData Json?

  // Pozycje zamówienia
  items OrderItem[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?


  shipments Shipment[]

  // Jedno konto marketplace nie może mieć dwa razy tego samego zamówienia z platformy
  @@unique([marketplaceAccountId, externalOrderId])

  @@index([userId])
  @@index([marketplace])
  @@index([userId, marketplace])
  @@index([marketplaceAccountId])
  @@index([userId, marketplaceAccountId])
  @@index([externalOrderId])
  @@index([status])
  @@index([externalOrderStatus])
  @@index([externalFulfillmentStatus])
  @@index([deliveryMethodName])
  @@index([buyerId])
  @@index([buyerEmail])
  @@index([marketplaceSiteId])
  @@index([externalRevision])
  @@index([paymentType])
  @@index([orderCreatedAt])
  @@index([externalUpdatedAt])
  @@index([syncedAt])
  @@index([userId, externalOrderStatus, externalFulfillmentStatus, orderCreatedAt])
  @@index([userId, marketplaceAccountId, externalOrderStatus, externalFulfillmentStatus])
  @@index([userId, marketplace, externalOrderStatus, externalFulfillmentStatus])
  @@index([userId, deliveryMethodName, orderCreatedAt])

  @@map("orders")
}

model OrderItem {
  // Lokalne ID pozycji zamówienia
  id Int @id @default(autoincrement())

  // Zamówienie, do którego należy pozycja
  orderId Int
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // ID pozycji z platformy, np. Allegro lineItems[].id albo ERLI item id
  externalLineItemId String?

  // ID oferty / produktu z platformy
  externalOfferId String?

  // Nazwa produktu
  productName String

  // Obrazek produktu / oferty
  productImageUrl String?

  // Ilość
  quantity Int @default(1)

  // Cena po rabacie
  price Decimal @default(0) @db.Decimal(12, 2)

  // Cena przed rabatem
  originalPrice Decimal? @db.Decimal(12, 2)

  // Waluta pozycji
  currency String @default("PLN")

  // Kiedy konkretna pozycja została kupiona
  boughtAt DateTime?

  // Surowe dane pozycji z API platformy
  rawData Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@index([externalLineItemId])
  @@index([externalOfferId])

  @@map("order_items")
}

model Session {
  id Int @id @default(autoincrement())

  userId Int
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Nie zapisuj czystego tokena sesji.
  // Zapisuj hash tokena.
  tokenHash String @unique

  expiresAt DateTime
  revokedAt DateTime?

  userAgent String?
  ipAddress String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model ShippingAccount {
  id Int @id @default(autoincrement())

  // Do którego usera AllePanel należy konto kurierskie
  userId Int
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Na razie INPOST_SHIPX, później można dodać DPD/DHL/UPS
  provider ShippingProvider

  // Nazwa widoczna w panelu, np. "InPost SolarTech"
  accountName String?

  // ID organizacji InPost ShipX
  organizationId String

  // Token ShipX — prywatny, nie zwracamy go nigdy na frontend
  apiToken String

  // Dane pobrane testowo z InPost organization
  organizationName String?
  organizationEmail String?

  // Status połączenia
  status ShippingAccountStatus @default(DISCONNECTED)

  // Ostatni błąd integracji
  errorMessage String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?


  shipments Shipment[]

  @@unique([provider, organizationId])
  @@index([userId])
  @@index([userId, provider])
  @@index([provider])
  @@index([status])

  @@map("shipping_accounts")
}










//shipments


enum ShipmentProvider {
  INPOST_SHIPX
  ALLEGRO_SHIPMENT_MANAGEMENT
  DPD
  DHL
  UPS
  OTHER
}

enum ShipmentStatus {
  DRAFT
  CREATED
  LABEL_READY
  SENT
  ERROR
  CANCELLED
}

enum ShipmentParcelSize {
  A
  B
  C
  CUSTOM
}

model Shipment {
  id Int @id @default(autoincrement())

  userId Int
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  orderId Int
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  shippingAccountId Int?
  shippingAccount ShippingAccount? @relation(fields: [shippingAccountId], references: [id], onDelete: SetNull)

  provider ShipmentProvider
  status ShipmentStatus @default(DRAFT)

  parcelSize ShipmentParcelSize?
  weightKg Decimal? @db.Decimal(10, 3)

  lengthCm Decimal? @db.Decimal(10, 2)
  widthCm Decimal? @db.Decimal(10, 2)
  heightCm Decimal? @db.Decimal(10, 2)

  externalCommandId String?
  externalShipmentId String?
  trackingNumber String?

  labelFormat String?
  labelPath String?

  errorMessage String?
  rawRequest Json?
  rawResponse Json?


  

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@index([userId])
  @@index([orderId])
  @@index([shippingAccountId])
  @@index([provider])
  @@index([status])
  @@index([trackingNumber])
  @@index([externalShipmentId])
  @@index([externalCommandId])

  @@map("shipments")
}